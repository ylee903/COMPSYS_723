#include "FreeRTOS/FreeRTOS.h"
#include "FreeRTOS/task.h"
#include "FreeRTOS/semphr.h"
#include "shared_state.h"

#define LOAD_MASK 0x1F

static int find_lowest_priority_on_not_shed(unsigned int allowed, unsigned int shed)
{
    int i;
    for (i = 0; i < 5; i++)
    {
        if ((allowed & (1U << i)) && !(shed & (1U << i)))
        {
            return i;
        }
    }
    return -1;
}

static int find_highest_priority_shed(unsigned int shed)
{
    int i;
    for (i = 4; i >= 0; i--)
    {
        if (shed & (1U << i))
        {
            return i;
        }
    }
    return -1;
}

void DecisionTask(void *pvParameters)
{
    unsigned int prevUnstable = 0;
    unsigned int requested;
    unsigned int allowed;
    unsigned int shed;
    unsigned int unstable;
    unsigned int maintenance;

    while (1)
    {
        if (xSemaphoreTake(sharedStateMutex, portMAX_DELAY) == pdTRUE)
        {
            requested = userRequestedLoads & LOAD_MASK;
            allowed = allowedLoads & LOAD_MASK;
            shed = relayShedLoads & LOAD_MASK;
            unstable = systemUnstable;
            maintenance = maintenanceMode;

            if (maintenance)
            {
                /* Maintenance mode: relay disabled */
                managingLoads = 0;
                relayShedLoads = 0;
                allowedLoads = requested;
                prevUnstable = unstable;

                xSemaphoreGive(sharedStateMutex);
                vTaskDelay(pdMS_TO_TICKS(100));
                continue;
            }

            /* Always allow user turn-offs.
               If user turns off a switch, remove it from allowed loads too. */
            allowed &= requested;

            /* If user turns off a switch, also clear its shed state */
            shed &= requested;

            if (!managingLoads)
            {
                /* Normal mode: loads follow switches directly */
                allowed = requested;

                if (unstable)
                {
                    int loadToShed;

                    /* Immediate first shed when instability detected */
                    loadToShed = find_lowest_priority_on_not_shed(allowed, shed);
                    if (loadToShed >= 0)
                    {
                        shed |= (1U << loadToShed);
                        managingLoads = 1;
                    }
                }
            }
            else
            {
                /* Managing mode */
                if (unstable != prevUnstable)
                {
                    /* State changed before 500 ms ends:
                       just reset observation by restarting delay cycle below */
                }
                else
                {
                    if (unstable)
                    {
                        /* Still unstable for another 500 ms: shed next lowest ON load */
                        int loadToShed = find_lowest_priority_on_not_shed(allowed, shed);
                        if (loadToShed >= 0)
                        {
                            shed |= (1U << loadToShed);
                        }
                    }
                    else
                    {
                        /* Stable for another 500 ms: restore highest-priority shed load */
                        int loadToRestore = find_highest_priority_shed(shed);
                        if (loadToRestore >= 0)
                        {
                            shed &= ~(1U << loadToRestore);
                        }

                        /* Exit managing mode when all loads restored */
                        if ((shed & LOAD_MASK) == 0)
                        {
                            managingLoads = 0;
                            allowed = requested;
                        }
                    }
                }
            }

            allowedLoads = allowed & LOAD_MASK;
            relayShedLoads = shed & LOAD_MASK;
            prevUnstable = unstable;

            xSemaphoreGive(sharedStateMutex);
        }

        /* 500 ms management interval */
        vTaskDelay(pdMS_TO_TICKS(500));
    }
}
