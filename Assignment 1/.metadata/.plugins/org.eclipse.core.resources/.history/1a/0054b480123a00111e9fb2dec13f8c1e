#include <math.h>

#include "FreeRTOS/FreeRTOS.h"
#include "FreeRTOS/task.h"
#include "FreeRTOS/semphr.h"
#include "shared_state.h"

#define LOAD_MASK 0x1F

static int find_lowest_priority_on_not_shed(unsigned int allowed, unsigned int shed)
{
    int i;
    for (i = 0; i < 5; i++)
    {
        if ((allowed & (1U << i)) && !(shed & (1U << i)))
        {
            return i;
        }
    }
    return -1;
}

static int find_highest_priority_shed(unsigned int shed)
{
    int i;
    for (i = 4; i >= 0; i--)
    {
        if (shed & (1U << i))
        {
            return i;
        }
    }
    return -1;
}

void DecisionTask(void *pvParameters)
{
    unsigned int requested;
    unsigned int allowed;
    unsigned int shed;
    unsigned int maintenance;
    unsigned int unstable;
    unsigned int prevUnstable = 0;

    TickType_t observationStartTick = 0;
    TickType_t now;

    while (1)
    {
        if (xSemaphoreTake(sharedStateMutex, portMAX_DELAY) == pdTRUE)
        {
            /* Read shared state */
            requested   = userRequestedLoads & LOAD_MASK;
            allowed     = allowedLoads & LOAD_MASK;
            shed        = relayShedLoads & LOAD_MASK;
            maintenance = maintenanceMode;

            /* Maintenance mode disables relay action */
            if (maintenance)
            {
                managingLoads = 0;
                systemUnstable = 0;
                relayShedLoads = 0;
                allowedLoads = requested;

                xSemaphoreGive(sharedStateMutex);
                vTaskDelay(pdMS_TO_TICKS(50));
                continue;
            }

            /* --- Real stability decision from old analyser logic --- */
            if ((currentFrequencyHz < frequencyThreshold) ||
                (fabsf(currentROCOF) > rocofThreshold))
            {
                unstable = 1;
            }
            else
            {
                unstable = 0;
            }

            systemUnstable = unstable;

            /* Always allow user turn-offs */
            allowed &= requested;

            /* If user turns a switch off, clear its shed bit too */
            shed &= requested;

            now = xTaskGetTickCount();

            if (!managingLoads)
            {
                /* Normal mode: loads follow switches */
                allowed = requested;

                if (unstable)
                {
                    int loadToShed;

                    /* Immediate first shed on instability */
                    loadToShed = find_lowest_priority_on_not_shed(allowed, shed);
                    if (loadToShed >= 0)
                    {
                        shed |= (1U << loadToShed);
                        managingLoads = 1;
                        observationStartTick = now;
                    }
                }
            }
            else
            {
                /* Reset 500 ms observation timer whenever stability changes */
                if (unstable != prevUnstable)
                {
                    observationStartTick = now;
                }
                else
                {
                    if ((now - observationStartTick) >= pdMS_TO_TICKS(500))
                    {
                        if (unstable)
                        {
                            /* Still unstable after 500 ms: shed next lowest-priority ON load */
                            int loadToShed = find_lowest_priority_on_not_shed(allowed, shed);
                            if (loadToShed >= 0)
                            {
                                shed |= (1U << loadToShed);
                            }
                        }
                        else
                        {
                            /* Stable for 500 ms: restore highest-priority shed load */
                            int loadToRestore = find_highest_priority_shed(shed);
                            if (loadToRestore >= 0)
                            {
                                shed &= ~(1U << loadToRestore);
                            }

                            /* Exit managing state when all shed loads restored */
                            if ((shed & LOAD_MASK) == 0)
                            {
                                managingLoads = 0;
                                allowed = requested;
                            }
                        }

                        /* Start a new 500 ms observation period */
                        observationStartTick = now;
                    }
                }
            }

            allowedLoads = allowed & LOAD_MASK;
            relayShedLoads = shed & LOAD_MASK;
            prevUnstable = unstable;

            xSemaphoreGive(sharedStateMutex);
        }

        /* Run often enough to catch instability quickly */
        vTaskDelay(pdMS_TO_TICKS(20));
    }
}
